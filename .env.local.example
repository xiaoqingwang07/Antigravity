# 复制为 .env.local（勿提交仓库）
#
# —— 上线推荐：服务端中转（Key 只在 Vercel/Worker 环境变量里）——
# 部署 api/llm-proxy.js 后填写完整地址；小程序需在后台配置 request 合法域名
# TARO_APP_LLM_PROXY_URL=https://你的项目.vercel.app/api/llm-proxy
# 若中转启用了 LLM_PROXY_SHARED_SECRET，再填（可选）
# TARO_APP_LLM_PROXY_SECRET=
#
# —— 仅本地开发直连 MiniMax（切勿把真实 Key 提交 Git）——
# TARO_APP_MINIMAX_API_KEY=
# TARO_APP_DEEPSEEK_API_KEY=
